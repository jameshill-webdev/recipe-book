// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PurchaseUnit {
  GRAM
  KILOGRAM
  MILLILITRE
  LITRE
  PACK
  UNIT
}

enum MeasureUnit {
  GRAM
  KILOGRAM
  MILLILITRE
  LITRE
  PACK
  UNIT
}

enum TimeUnit {
  SECOND
  MINUTE
  HOUR
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  displayName             String?                  @map("display_name")
  emailAddress            String                   @unique @map("email_address") @db.VarChar(320)
  passwordHash            String                   @map("password_hash")
  emailVerifiedAt         DateTime?                @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  ingredients             Ingredient[]
  recipes                 Recipe[]
  recipeIngredients       RecipeIngredient[]
  recipeSteps             RecipeStep[]

  @@map("users")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Ingredient {
  id                String             @id @default(uuid()) @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId            String             @map("user_id") @db.Uuid
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  purchaseUnit      PurchaseUnit
  costPerUnit       Decimal            @db.Decimal(10, 2)
  recipeIngredients RecipeIngredient[] @relation("IngredientToRecipeIngredient")

  @@unique([userId, id])
  @@unique([userId, name])
  @@index([userId])
  @@map("ingredients")
}

model Recipe {
  id            String             @id @default(uuid()) @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId        String             @map("user_id") @db.Uuid
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  ingredients   RecipeIngredient[] @relation("RecipeToRecipeIngredient")
  method        RecipeStep[]       @relation("RecipeToRecipeStep")
  prepTime      Float
  prepTimeUnit  TimeUnit
  cookTime      Float
  cookTimeUnit  TimeUnit
  shelfLifeDays Int
  portions      Int

  @@unique([userId, id])
  @@unique([userId, name])
  @@index([userId])
  @@map("recipes")
}

model RecipeIngredient {
  id           String      @id @default(uuid()) @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId       String      @map("user_id") @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId     String      @map("recipe_id") @db.Uuid
  ingredientId String      @map("ingredient_id") @db.Uuid
  recipe       Recipe      @relation("RecipeToRecipeIngredient", fields: [userId, recipeId], references: [userId, id], onDelete: Cascade)
  ingredient   Ingredient  @relation("IngredientToRecipeIngredient", fields: [userId, ingredientId], references: [userId, id], onDelete: Cascade)
  quantity     Float
  unit         MeasureUnit

  @@unique([userId, recipeId, ingredientId])
  @@index([userId])
  @@index([userId, recipeId])
  @@index([userId, ingredientId])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id         String   @id @default(uuid()) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId   String   @map("recipe_id") @db.Uuid
  recipe     Recipe   @relation("RecipeToRecipeStep", fields: [userId, recipeId], references: [userId, id], onDelete: Cascade)
  stepNumber Int      @map("step_number")
  text       String   @db.VarChar(4096)

  @@unique([userId, recipeId, stepNumber])
  @@index([userId])
  @@index([userId, recipeId])
  @@index([userId, recipeId, stepNumber])
  @@map("recipe_steps")
}
