{
	"name": "recipe-book-api",
	"version": "1.0.0",
	"description": "Express API application for recipe book",
	"license": "no license",
	"author": "James Hill",
	"type": "module",
	"main": "server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"build": "tsc",
		"start": "node dist/server.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"prisma-format": "npx prisma format",
		"prisma-validate": "npx prisma validate",
		"prisma-migrate-dev": "npx prisma migrate dev",
		"prisma-migrate-prod": "npx prisma migrate deploy",
		"prisma-migrate-reset": "npx prisma migrate reset"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@recipe-book/shared": "*",
		"better-auth": "^1.4.19",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"pg": "^8.18.0",
		"resend": "^6.9.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.3.0",
		"@types/pg": "^8.11.11",
		"eslint": "^9.39.4",
		"globals": "^16.5.0",
		"prisma": "^7.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vitest": "^4.0.18"
	}
}
