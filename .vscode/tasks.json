{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-api",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "cd ${workspaceFolder}/api && npm run build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$tsc",
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}
